{
  "expo": {
    "name": "Sabd",
    "slug": "sabd",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sabd",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "backgroundColor": "#171A24",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#171A24"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sabd.app"
    },
    "android": {
      "package": "com.sabd.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#171A24"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#171A24",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
