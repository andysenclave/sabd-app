{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    // The @sabd/* workspace packages import sibling modules with explicit `.ts`
    // extensions (required for Node-native TS execution). Allow that here so tsc can
    // typecheck through them; Metro resolves the same specifiers at bundle time.
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
