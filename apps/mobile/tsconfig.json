{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    // The @sabd/* workspace packages import sibling modules with explicit `.ts`
    // extensions (required for Node-native TS execution). Allow that here so tsc can
    // typecheck through them; Metro resolves the same specifiers at bundle time.
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  // test/ runs under Node (node --test) and typechecks via tsconfig.test.json —
  // keeping node globals out of the RN app's type space.
  "exclude": ["node_modules", "test"]
}
