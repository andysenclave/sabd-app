    "test": "node --test \"test/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=23.6"
  },
  "dependencies": {
    "@sabd/contracts": "workspace:*",
    "@sabd/elo": "workspace:*"
  },
  "devDependencies": {
    "@sabd/storage": "workspace:*",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
