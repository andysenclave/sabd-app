{
  "name": "@sabd/correction",
  "version": "0.1.0",
  "description": "Sabd word self-calibration (Phase-3 T15-T17) — weekly aggregation over ingested events, difficulty nudges from real solve rates, human review for tier crossings.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
