{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@sabd/contracts": ["packages/contracts/src/index.ts"],
      "@sabd/elo": ["packages/elo/src/index.ts"],
      "@sabd/storage": ["packages/storage/src/index.ts"],
      "@sabd/tokens": ["packages/tokens/src/index.ts"],
      "@sabd/wordbank": ["packages/wordbank/src/index.ts"]
    }
  }
}
